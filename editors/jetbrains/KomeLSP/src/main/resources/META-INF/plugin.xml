<idea-plugin>
    <id>org.mochios.kome.lsp</id>
    <name>Kome</name>
    <vendor>mochiOS</vendor>

    <description><![CDATA[
        Kome language support for JetBrains IDEs.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lsp</depends>
    <depends>com.intellij.modules.ultimate</depends>

    <extensions defaultExtensionNs="com.intellij">
        <platform.lsp.serverSupportProvider
                implementation="org.mochios.kome.lsp.KomeLspServerSupportProvider"/>
    </extensions>
</idea-plugin>