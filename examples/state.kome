use libc.stdio
use os.keyboard

bundle App {
    public state let mut Index = 0;

    recipe button: Index = {
        printf("Button pressed: %d\n", Index)
    }
}

fn main() {
    let app = App;              // Appバンドルをインスタンス化

    keyboard.onPress(any) {
        app.Index += 1;         // キーが押されるたびにIndexをインクリメント
    };
}

