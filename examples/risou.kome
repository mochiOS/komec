use viewkit
use std.bundle

bundle HelloScreen {
  public state let mut count = 0

  recipe counter(count) {
    text(count)
  }

  recipe countButton {
    button("Countup") {
      count += 1
    }
  }

  recipe body(count) {
    countButton
    counter
  }
}

fn main() {
  app HelloApp {
    window {
      HelloScreen()
    }
  }
}