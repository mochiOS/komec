use libc.stdio

fn main() {
    let a = 5
    let b = 10
    let c = a + b

    printf("The sum of %d and %d is %d\n", a, b, c)

    if c > 10 {
        printf("The sum is greater than 10\n")
    } else {
        printf("The sum is not greater than 10\n")
    }

    while c > 0 {
        printf("Current value of c: %d\n", c)
        c -= 1
    }

    for i in 0..5 {
        printf("Loop iteration: %d\n", i)
    }
}