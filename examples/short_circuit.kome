use std.io

fn t() -> Bool {
    io.println("t called")
    true
}

fn f() -> Bool {
    io.println("f called")
    false
}

fn main() {
    let mut a = false && t()
    let mut b = true || f()

    if a { io.println("a=true") } else { io.println("a=false") }
    if b { io.println("b=true") } else { io.println("b=false") }
}

