cinclude "viewkit.h"

fn create() -> Ptr {
    kome_viewkit_app_create()
}

fn destroy(app: Ptr) {
    if app != none {
        kome_viewkit_app_destroy(app)
    } else {
        // 何もしない
    }
}

fn run(app: Ptr) {
    kome_viewkit_app_run(app)
}

fn runAsync(app: Ptr) {
    kome_viewkit_app_run_async(app)
}
